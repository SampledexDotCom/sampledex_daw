{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022",
      "displayName": "Windows VS2022 x64",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/build/windows-vs2022",
      "cacheVariables": {
        "CMAKE_POLICY_DEFAULT_CMP0091": "NEW",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>",
        "SAMPLEXDEX_WINDOWS_BUILD": "ON",
        "BUILD_TESTING": "ON",
        "FETCHCONTENT_UPDATES_DISCONNECTED": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release",
      "targets": [
        "TheSampledexWorkflow",
        "BeatMakerNoRecordUiRegressionTests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "windows-vs2022-release-tests",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    }
  ]
}
